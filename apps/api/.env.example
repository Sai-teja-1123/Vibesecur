# ============================================================
#  Vibesecur — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vibesecur
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
BCRYPT_ROUNDS=12

# ── Security ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
WATERMARK_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
PASSPORT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── AI (Claude API) ──────────────────────────────────────────
# Used ONLY for hosted AI mode (not BYOK)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_SOLO=price_YOUR_SOLO_PRICE_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_KEY
FROM_EMAIL=hello@vibesecur.dev

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
